{
    "name": "distributed-oms",
    "version": "0.0.0",
    "private": true,
    "devDependencies": {
        "@commitlint/cli": "^21.0.1",
        "@commitlint/config-conventional": "^21.0.1",
        "@nestjs/schematics": "^11.0.0",
        "@nestjs/testing": "^11.0.0",
        "@nx/eslint": "^22.7.2",
        "@nx/eslint-plugin": "^22.7.2",
        "@nx/jest": "22.7.2",
        "@nx/js": "22.7.2",
        "@nx/nest": "22.7.2",
        "@nx/node": "22.7.2",
        "@nx/web": "22.7.2",
        "@nx/webpack": "22.7.2",
        "@swc-node/register": "~1.11.1",
        "@swc/core": "~1.15.5",
        "@swc/helpers": "~0.5.18",
        "@types/express": "^5.0.6",
        "@types/fs-extra": "^11.0.4",
        "@types/jest": "~30.0.0",
        "@types/node": "20.19.9",
        "@typescript-eslint/eslint-plugin": "^8.59.3",
        "@typescript-eslint/parser": "^8.59.3",
        "eslint": "^10.3.0",
        "husky": "^9.1.7",
        "jest": "~30.3.0",
        "jest-environment-node": "~30.3.0",
        "jest-util": "~30.3.0",
        "jsonc-eslint-parser": "^2.1.0",
        "lint-staged": "^17.0.4",
        "nx": "22.7.2",
        "prettier": "^3.8.3",
        "terser-webpack-plugin": "^5.6.1",
        "ts-jest": "^29.4.0",
        "ts-loader": "^9.6.2",
        "ts-node": "10.9.1",
        "tsconfig-paths": "^4.2.0",
        "tsconfig-paths-webpack-plugin": "^4.2.0",
        "tslib": "^2.3.0",
        "tsx": "^4.23.0",
        "typescript": "~5.9.2",
        "webpack": "^5.108.4",
        "webpack-cli": "^5.1.4",
        "webpack-node-externals": "^3.0.0"
    },
    "scripts": {
        "prepare": "husky",
        "lint": "nx run-many -t lint",
        "test": "nx run-many -t test",
        "infra:up": "docker compose -f ./infra/compose.yaml up -d",
        "infra:down": "docker compose -f ./infra/compose.yaml down",
        "migration:run:order": "tsx libs/order/infrastructure/src/lib/db-configs/migration.config.ts",
        "migration:run:inventory": "tsx libs/inventory/infrastructure/src/lib/db-configs/migration.config.ts",
        "start:order-capture": "tsx apps/order-capture/src/main.ts",
        "typeorm": "node -r @swc-node/register -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
        "migration:generate": "pnpm typeorm migration:generate",
        "migration:revert": "pnpm typeorm migration:revert"
    },
    "lint-staged": {
        "*.{ts,js,json}": [
            "prettier --write"
        ],
        "*.{ts,js}": [
            "eslint --fix"
        ]
    },
    "dependencies": {
        "@nestjs-modules/ioredis": "^2.2.1",
        "@nestjs/common": "^11.0.0",
        "@nestjs/config": "^4.0.4",
        "@nestjs/core": "^11.0.0",
        "@nestjs/cqrs": "^11.0.3",
        "@nestjs/microservices": "^11.1.27",
        "@nestjs/platform-express": "^11.0.0",
        "@nestjs/schedule": "^6.1.3",
        "@nestjs/swagger": "^11.4.4",
        "@nestjs/typeorm": "^11.0.2",
        "axios": "^1.6.0",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.15.1",
        "dotenv": "^17.4.2",
        "fs-extra": "^11.3.6",
        "glob": "^13.0.6",
        "ioredis": "^5.11.1",
        "kafkajs": "^2.2.4",
        "nest-winston": "^1.10.2",
        "pg": "^8.21.0",
        "reflect-metadata": "^0.1.13",
        "rxjs": "^7.8.0",
        "swagger-ui-express": "^5.0.1",
        "typeorm": "^1.0.0",
        "winston": "^3.19.0",
        "zod": "^4.4.3"
    }
}
